#N canvas 827 239 800 600 12;
#X obj 50 50 netreceive -u -l 9999;
#X obj 50 100 oscparse;
#X obj 50 150 route /synth/pitch /synth/mode /synth/vibrato /synth/expression /synth/volume /synth/panic;
#X obj 50 250 osc~ 440;
#X obj 50 350 *~ 0.5;
#X obj 50 450 dac~;
#X obj 250 150 print pitch;
#X obj 350 150 print mode;
#X obj 450 150 print vibrato;
#X obj 550 150 print expression;
#X obj 650 150 print volume;
#X obj 750 150 print panic;
#X msg 50 200 440;
#X floatatom 50 250 5 0 0 0 - - -;
#X floatatom 50 300 5 0 0 0 - - -;
#X obj 50 330 *;
#X msg 50 360 \; pd dsp 1;
#X connect 0 0 1 0;
#X connect 1 0 2 0;
#X connect 2 0 6 0;
#X connect 2 1 7 0;
#X connect 2 2 8 0;
#X connect 2 3 9 0;
#X connect 2 4 10 0;
#X connect 2 5 11 0;
#X connect 12 0 3 0;
#X connect 13 0 15 0;
#X connect 14 0 15 1;
#X connect 15 0 4 0;
